/* этот файл хранит общие стили для всех HTML-страниц сайта. */
/* после разделения структуры страницы остались разными, но визуальная система подключается одна. */
/* ниже объявлены CSS-переменные светлой темы: фон, текст, линии, акценты, тени и радиусы. */
:root {
  --bg: #f5f7f9;
  --bg-raised: #ffffff;
  --bg-soft: #eef2f5;
  --ink: #111315;
  --ink-soft: #2c3033;
  --muted: #6c7072;
  --muted-2: #8b8d8d;
  --line: #d9e0e6;
  --line-strong: #bdc7d0;
  --panel: #ffffff;
  --panel-dark: #17191b;
  --panel-dark-2: #222528;
  --accent: #5e666d;
  --accent-soft: #eef3f6;
  --danger: #8d5149;
  --danger-line: #d2b8b3;
  --positive: #2f5f46;
  --negative: #7a4a43;
  --focus-ring: rgba(17, 19, 21, 0.08);
  --page-frame: rgba(17, 19, 21, 0.025);
  --glass-bg: rgba(255, 255, 255, 0.94);
  --mobile-glass-bg: rgba(255, 255, 255, 0.96);
  --inverse-ink: #ffffff;
  --inverse-ink-soft: #f8fafc;
  --inverse-muted: #d2d4d4;
  --inverse-panel: #17191b;
  --inverse-panel-2: #222528;
  --inverse-line: #303336;
  --inverse-line-strong: #484d51;
  --theme-color: #f5f7f9;
  --radius: 8px;
  --shadow: 0 22px 54px rgba(17, 19, 21, 0.12);
  --shadow-soft: 0 12px 30px rgba(17, 19, 21, 0.08);
}

/* темная тема переопределяет только переменные, поэтому остальные правила не нужно дублировать. */
:root[data-theme="dark"] {
  color-scheme: dark;
  --bg: #101316;
  --bg-raised: #171b1f;
  --bg-soft: #20262b;
  --ink: #f3f6f8;
  --ink-soft: #d5dbe0;
  --muted: #a7b0b8;
  --muted-2: #87929c;
  --line: #2b333a;
  --line-strong: #45505a;
  --panel: #171b1f;
  --panel-dark: #0d1013;
  --panel-dark-2: #171c21;
  --accent: #9aa8b4;
  --accent-soft: #222930;
  --danger: #e18f84;
  --danger-line: #6b403a;
  --positive: #8fd4ad;
  --negative: #f1a59c;
  --focus-ring: rgba(243, 246, 248, 0.16);
  --page-frame: rgba(243, 246, 248, 0.03);
  --glass-bg: rgba(23, 27, 31, 0.92);
  --mobile-glass-bg: rgba(23, 27, 31, 0.94);
  --theme-color: #101316;
  --shadow: 0 24px 60px rgba(0, 0, 0, 0.34);
  --shadow-soft: 0 14px 34px rgba(0, 0, 0, 0.24);
}

/* базовый сброс помогает всем элементам одинаково считать размеры с учетом padding и border. */
* {
  box-sizing: border-box;
}

/* изображения не выходят за ширину контейнера и ведут себя как блочные элементы. */
img {
  display: block;
  max-width: 100%;
}

/* длинные русские слова и названия услуг можно переносить, чтобы верстка не ломалась на мобильных. */
h1,
h2,
h3,
p,
a,
button,
span,
strong,
small,
label {
  overflow-wrap: anywhere;
}

/* плавная прокрутка используется для якорных блоков главной страницы: покрытие, поддержка, отзывы. */
html {
  scroll-behavior: smooth;
  overflow-x: hidden;
}

/* основные настройки страницы задают шрифт, цвет текста и минимальную ширину интерфейса. */
body {
  margin: 0;
  min-width: 320px;
  overflow-x: hidden;
  color: var(--ink);
  background: var(--bg);
  font-family: Inter, "Segoe UI", Arial, sans-serif;
  line-height: 1.5;
}

/* список ниже получает общий переход цветов, чтобы смена темы выглядела плавно. */
body,
.topbar,
.mobile-nav,
.navigator-popover,
dialog,
.tariff-card,
.service-card,
.info-card,
.promo-offer,
.legal-section,
.compare-panel,
.filters,
.balance-panel,
.usage-panel,
.checkout-panel,
.cart-item,
.admin-table,
.centered-page,
.faq-list details,
.coverage-info,
.account-panel,
.cabinet-summary,
.cabinet-card,
.admin-form,
.admin-tools,
.feedback-panel,
.reviews-panel,
.map-panel {
  transition: background-color 0.24s ease, color 0.24s ease, border-color 0.24s ease, box-shadow 0.24s ease;
}

/* декоративная рамка страницы сделана через псевдоэлемент и не мешает кликам по интерфейсу. */
body::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  border: 16px solid var(--page-frame);
  opacity: 0.55;
}

/* цвет выделения текста подстроен под текущую палитру сайта. */
::selection {
  color: #ffffff;
  background: var(--ink);
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
select {
  font: inherit;
}

button {
  cursor: pointer;
  max-width: 100%;
  text-align: center;
  white-space: normal;
  overflow-wrap: anywhere;
}

svg {
  display: block;
  width: 20px;
  height: 20px;
  fill: none;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  margin-bottom: 18px;
  font-size: 62px;
  line-height: 1;
  letter-spacing: 0;
}

h2 {
  margin-bottom: 16px;
  font-size: 34px;
  line-height: 1.12;
  letter-spacing: 0;
}

h3 {
  margin-bottom: 8px;
  font-size: 20px;
  line-height: 1.2;
  letter-spacing: 0;
}

p {
  color: var(--muted);
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(14px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(24px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes softPulse {
  0%,
  100% {
    box-shadow: 0 0 0 0 var(--focus-ring);
  }

  50% {
    box-shadow: 0 0 0 8px transparent;
  }
}

@keyframes floatPanel {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-10px);
  }
}

@keyframes compareHighlight {
  0% {
    border-color: var(--ink);
    box-shadow: 0 0 0 4px var(--focus-ring), var(--shadow-soft);
  }

  100% {
    border-color: var(--line);
    box-shadow: var(--shadow-soft);
  }
}

.app-shell {
  width: min(1180px, calc(100% - 32px));
  margin: 0 auto;
}

.topbar {
  position: sticky;
  top: 12px;
  z-index: 30;
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 18px;
  align-items: center;
  min-height: 76px;
  margin-top: 12px;
  padding: 10px 12px;
  background: var(--glass-bg);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow-soft);
  backdrop-filter: blur(16px);
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.brand-logo {
  width: 48px;
  height: 48px;
  border-radius: var(--radius);
  box-shadow: 0 10px 24px rgba(17, 19, 21, 0.14);
  animation: softPulse 4s ease-in-out infinite;
}

.brand-copy {
  display: grid;
  line-height: 1.1;
}

.brand-copy strong {
  color: var(--ink);
  font-size: 18px;
}

.brand-copy small {
  color: var(--muted);
  font-size: 12px;
}

.main-nav {
  display: flex;
  justify-content: center;
  gap: 4px;
}

.main-nav a,
.main-nav button,
.admin-tabs button {
  position: relative;
  min-width: 0;
  max-width: 100%;
  min-height: 42px;
  padding: 10px 12px;
  color: var(--muted);
  background: transparent;
  border: 1px solid transparent;
  border-radius: var(--radius);
  text-align: center;
  line-height: 1.15;
  white-space: normal;
  overflow-wrap: anywhere;
  transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
}

.main-nav a:hover,
.main-nav a.is-active,
.main-nav button:hover,
.main-nav button.is-active,
.admin-tabs button:hover,
.admin-tabs button.is-active {
  color: var(--ink);
  background: var(--accent-soft);
  border-color: var(--line);
  transform: translateY(-1px);
}

.main-nav .navigator-toggle {
  display: inline-flex;
  gap: 6px;
  align-items: center;
}

.navigator-toggle .chevron-down {
  width: 16px;
  height: 16px;
  transition: transform 0.18s ease;
}

.navigator-toggle.is-open .chevron-down {
  transform: rotate(180deg);
}

.top-actions,
.hero-actions,
.page-actions,
.cabinet-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}

.top-actions {
  justify-content: end;
}

.icon-button,
.cart-pill,
.slider-arrow,
.dialog-close {
  display: inline-grid;
  place-items: center;
  min-width: 44px;
  height: 44px;
  color: var(--ink);
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
}

.theme-toggle {
  position: relative;
}

.theme-icon {
  transition: opacity 0.18s ease, transform 0.18s ease;
}

.moon-icon {
  position: absolute;
  opacity: 0;
  transform: scale(0.74) rotate(-18deg);
}

:root[data-theme="dark"] .sun-icon {
  opacity: 0;
  transform: scale(0.74) rotate(18deg);
}

:root[data-theme="dark"] .moon-icon {
  opacity: 1;
  transform: scale(1) rotate(0);
}

.cart-pill {
  grid-template-columns: 20px auto;
  gap: 6px;
  padding: 0 12px;
}

.cart-pill span {
  min-width: 20px;
  text-align: center;
  font-weight: 800;
}

.icon-button:hover,
.cart-pill:hover,
.slider-arrow:hover,
.dialog-close:hover {
  transform: translateY(-2px);
  border-color: var(--line-strong);
  box-shadow: var(--shadow-soft);
}

.page {
  display: none;
  padding: 46px 0 34px;
}

.page.is-active {
  display: block;
  animation: pageEnter 0.38s ease both;
}

.full-bleed-slider {
  position: relative;
  width: 100vw;
  min-height: calc(100svh - 100px);
  margin: 0 0 52px;
  margin-left: calc(50% - 50vw);
  color: var(--inverse-ink-soft);
  background: var(--inverse-panel);
  border-top: 1px solid var(--inverse-line);
  border-bottom: 1px solid var(--inverse-line);
  overflow: hidden;
}

.slider-viewport {
  overflow: hidden;
}

.full-bleed-slider .slider-viewport {
  min-height: calc(100svh - 100px);
}

.slider-track {
  display: flex;
  height: 100%;
  transition: transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1);
  will-change: transform;
}

.promo-slide {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.75fr);
  gap: 44px;
  align-items: center;
  flex: 0 0 100%;
  min-height: calc(100svh - 100px);
  padding: 66px max(32px, calc((100vw - 1180px) / 2 + 16px)) 92px;
  overflow: hidden;
}

.promo-slide::before {
  content: "";
  position: absolute;
  inset: 28px;
  z-index: 2;
  border: 1px solid rgba(248, 250, 252, 0.12);
  border-radius: var(--radius);
  pointer-events: none;
}

.promo-slide::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  background:
    linear-gradient(90deg, rgba(17, 19, 21, 0.9) 0%, rgba(17, 19, 21, 0.72) 40%, rgba(17, 19, 21, 0.34) 72%, rgba(17, 19, 21, 0.5) 100%),
    linear-gradient(0deg, rgba(17, 19, 21, 0.38), rgba(17, 19, 21, 0.1));
  pointer-events: none;
}

.promo-copy {
  position: relative;
  z-index: 3;
  max-width: 760px;
  animation: fadeUp 0.6s ease both;
}

.promo-copy h1 {
  color: #ffffff;
  font-size: 64px;
  max-width: 790px;
}

.promo-copy p:not(.eyebrow) {
  max-width: 620px;
  color: #d2d4d4;
  font-size: 21px;
}

.promo-visual {
  position: relative;
  z-index: 3;
  display: grid;
  justify-items: end;
  align-content: center;
  gap: 14px;
  min-height: 420px;
  border: 0;
  border-radius: var(--radius);
  background: transparent;
  overflow: visible;
}

.promo-photo {
  position: absolute;
  inset: 0;
  z-index: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: saturate(0.96) contrast(0.98);
}

.promo-visual > :not(.promo-photo) {
  z-index: 2;
}

.promo-visual::before {
  z-index: 1;
  background: transparent;
}

.promo-visual::before,
.promo-visual::after {
  display: none;
}

.promo-visual::before {
  inset: 24px;
}

.promo-visual::after {
  z-index: 1;
  inset: 58px 46px;
}

.visual-phone,
.visual-meter,
.visual-server {
  position: absolute;
  right: 54px;
  bottom: 42px;
  display: grid;
  place-items: center;
  width: 190px;
  height: 280px;
  color: #111315;
  background: #f8fafc;
  border: 10px solid #111315;
  border-radius: 24px;
  box-shadow: 0 22px 36px rgba(0, 0, 0, 0.28);
}

.visual-phone::before {
  content: "";
  width: 74px;
  height: 8px;
  margin-top: 18px;
  align-self: start;
  background: #111315;
  border-radius: 999px;
}

.visual-phone::after {
  content: "";
  width: 112px;
  height: 96px;
  background: #dce3e9;
  border: 1px solid #cdcdc7;
  border-radius: var(--radius);
  box-shadow:
    inset 0 18px 0 #f1f5f8,
    inset 0 42px 0 #dce3e9,
    inset 0 66px 0 #f1f5f8;
}

.visual-phone.wide {
  width: 230px;
}

.visual-meter {
  right: 70px;
  bottom: 70px;
  width: 210px;
  height: 210px;
  border-width: 8px;
  border-radius: 50%;
  font-weight: 900;
}

.visual-meter b {
  display: block;
  font-size: 64px;
  line-height: 0.9;
}

.visual-meter small {
  color: var(--muted);
  font-size: 18px;
}

.visual-server {
  right: 58px;
  bottom: 58px;
  width: 250px;
  height: 190px;
  border-radius: var(--radius);
}

.visual-server::before,
.visual-server::after {
  content: "";
  position: absolute;
  left: 28px;
  right: 28px;
  height: 34px;
  border: 1px solid #bfc1bd;
  border-radius: var(--radius);
}

.visual-server::before {
  top: 48px;
}

.visual-server::after {
  bottom: 48px;
}

.visual-card {
  position: absolute;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112px;
  min-height: 52px;
  padding: 10px 14px;
  color: #111315;
  background: #f8fafc;
  border: 1px solid #c9cbc7;
  border-radius: var(--radius);
  font-weight: 900;
  box-shadow: 0 18px 34px rgba(0, 0, 0, 0.22);
}

.visual-card-a {
  top: 74px;
  left: 50px;
}

.visual-card-b {
  right: 46px;
  top: 120px;
}

.visual-signal,
.visual-dot,
.visual-line {
  position: absolute;
  display: block;
  border: 1px solid #8d9296;
}

.visual-signal {
  left: 58px;
  bottom: 72px;
  width: 138px;
  height: 80px;
  border-bottom: 0;
  border-radius: 138px 138px 0 0;
}

.visual-signal-b {
  left: 88px;
  bottom: 100px;
  width: 78px;
  height: 46px;
}

.visual-dot {
  width: 18px;
  height: 18px;
  background: #f8fafc;
  border-radius: 50%;
  animation: softPulse 3.4s ease-in-out infinite;
}

.dot-a {
  left: 92px;
  bottom: 92px;
}

.dot-b {
  left: 150px;
  bottom: 160px;
}

.dot-c {
  left: 84px;
  top: 156px;
}

.visual-line {
  left: 74px;
  width: 150px;
  height: 1px;
  background: #8d9296;
  transform-origin: left center;
}

.line-a {
  top: 170px;
  transform: rotate(18deg);
}

.line-b {
  bottom: 132px;
  transform: rotate(-16deg);
}

.slide-dashboard,
.slide-feature-list {
  width: min(360px, 100%);
  color: #ffffff;
  background: rgba(17, 19, 21, 0.58);
  border: 1px solid rgba(248, 250, 252, 0.2);
  border-radius: var(--radius);
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
  backdrop-filter: blur(14px);
}

.slide-dashboard {
  display: grid;
  gap: 12px;
  min-height: 230px;
  padding: 24px;
}

.slide-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  justify-self: start;
  max-width: 100%;
  min-height: 28px;
  padding: 4px 10px;
  color: #111315;
  background: #ffffff;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 900;
  text-align: center;
  line-height: 1.15;
  text-transform: uppercase;
  overflow-wrap: anywhere;
}

.slide-dashboard strong {
  display: block;
  font-size: clamp(42px, 5vw, 68px);
  line-height: 0.95;
}

.slide-dashboard small {
  color: #d7d9d9;
  font-size: 17px;
  font-weight: 700;
}

.slide-progress {
  height: 10px;
  margin-top: 10px;
  overflow: hidden;
  background: rgba(248, 250, 252, 0.22);
  border-radius: 999px;
}

.slide-progress span {
  display: block;
  width: var(--value);
  height: 100%;
  background: #ffffff;
  border-radius: inherit;
}

.slide-feature-list {
  display: grid;
  gap: 0;
  padding: 8px;
}

.slide-feature-list span {
  display: grid;
  place-items: center;
  min-height: 48px;
  padding: 13px 14px;
  text-align: center;
  font-weight: 900;
}

.slide-feature-list span + span {
  color: #111315;
  background: rgba(255, 255, 255, 0.88);
  border-radius: calc(var(--radius) - 2px);
}

.slider-controls {
  position: absolute;
  right: 0;
  bottom: 34px;
  left: 0;
  z-index: 6;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
  padding: 0 18px;
}

.full-bleed-slider .slider-arrow {
  color: #f8fafc;
  background: #222528;
  border-color: #3c4043;
}

.slider-dots {
  display: flex;
  gap: 8px;
  align-items: center;
}

.slider-dot {
  width: 9px;
  height: 9px;
  padding: 0;
  background: #8d9296;
  border: 0;
  border-radius: 999px;
  transition: width 0.2s ease, background 0.2s ease;
}

.slider-dot.is-active {
  width: 34px;
  background: #f8fafc;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  min-height: 28px;
  margin: 0 0 12px;
  padding: 4px 10px;
  color: var(--ink);
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: 999px;
  font-size: 12px;
  font-weight: 800;
  text-align: center;
  line-height: 1.15;
  letter-spacing: 0;
  text-transform: uppercase;
  overflow-wrap: anywhere;
}

.promo-slide .eyebrow {
  color: #f8fafc;
  background: #2f3336;
  border-color: #484d51;
}

.primary-button,
.ghost-button,
.secondary-button,
.remove-button,
.mini-button {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-width: 0;
  max-width: 100%;
  min-height: 48px;
  padding: 13px 18px;
  color: var(--ink);
  background: var(--panel);
  border: 1px solid var(--line-strong);
  border-radius: var(--radius);
  font-weight: 800;
  text-align: center;
  line-height: 1.15;
  white-space: normal;
  overflow-wrap: anywhere;
  transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
}

.primary-button {
  color: var(--bg-raised);
  background: var(--ink);
  border-color: var(--ink);
}

.primary-button:hover,
.ghost-button:hover,
.secondary-button:hover,
.remove-button:hover,
.mini-button:hover {
  transform: translateY(-2px);
  border-color: var(--ink);
  box-shadow: var(--shadow-soft);
}

.ghost-button,
.secondary-button {
  background: var(--panel);
}

.secondary-button {
  background: var(--accent-soft);
}

.secondary-button[aria-pressed="true"] {
  color: var(--bg-raised);
  background: var(--ink);
  border-color: var(--ink);
}

.remove-button {
  color: var(--danger);
  border-color: var(--danger-line);
}

.mini-button {
  min-height: 38px;
  padding: 8px 11px;
}

button:disabled,
.primary-button:disabled,
.ghost-button:disabled,
.secondary-button:disabled {
  cursor: not-allowed;
  opacity: 0.48;
  transform: none;
  box-shadow: none;
}

.compact {
  min-height: 44px;
  padding: 10px 14px;
}

.full {
  width: 100%;
}

.content-band {
  padding: 42px 0;
  border-bottom: 1px solid var(--line);
}

.section-heading,
.page-head {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  align-items: flex-end;
  margin-bottom: 22px;
}

.compact-heading {
  margin-bottom: 14px;
}

.section-heading h2,
.page-head h1 {
  margin-bottom: 0;
}

.text-link {
  color: var(--ink);
  border-bottom: 1px solid var(--ink);
  font-weight: 800;
}

.tariff-grid,
.service-grid,
.service-row,
.support-grid,
.metric-grid {
  display: grid;
  gap: 16px;
}

.tariff-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.service-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.service-row {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.support-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.promo-offer-grid,
.legal-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.tariff-card,
.service-card,
.info-card,
.promo-offer,
.legal-section,
.compare-panel,
.filters,
.balance-panel,
.usage-panel,
.checkout-panel,
.cart-item,
.admin-table,
.centered-page,
.faq-list details,
.coverage-map,
.coverage-info {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow-soft);
}

.tariff-card,
.service-card,
.info-card,
.promo-offer,
.legal-section {
  display: grid;
  gap: 14px;
  min-height: 250px;
  padding: 20px;
  overflow: hidden;
  transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
}

.card-photo,
.offer-photo {
  width: calc(100% + 40px);
  max-width: none;
  height: 170px;
  margin: -20px -20px 2px;
  object-fit: cover;
  border-bottom: 1px solid var(--line);
}

.offer-photo {
  height: 220px;
}

.tariff-card:hover,
.service-card:hover,
.info-card:hover,
.promo-offer:hover,
.legal-section:hover {
  transform: translateY(-4px);
  border-color: var(--line-strong);
  box-shadow: var(--shadow);
}

.tariff-card header,
.service-card header {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 12px;
  align-items: flex-start;
}

.tariff-card header > div,
.service-card header > div {
  min-width: 0;
}

.tariff-card small,
.service-card small,
.checkout-row span,
.usage-item span,
.footer span,
.operations-list span,
.admin-table span {
  color: var(--muted);
}

.tag,
.status-pill,
.promo-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  min-height: 28px;
  padding: 4px 9px;
  color: var(--ink);
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: 999px;
  font-size: 12px;
  font-weight: 800;
  text-align: center;
  line-height: 1.15;
  white-space: normal;
  overflow-wrap: anywhere;
}

.promo-badge {
  justify-self: start;
  color: #ffffff;
  background: var(--ink);
  border-color: var(--ink);
}

:root[data-theme="dark"] .promo-badge {
  color: #101316;
  background: #f3f6f8;
  border-color: #f3f6f8;
}

:root[data-theme="dark"] .promo-offer {
  background: #171d22;
  border-color: #34404a;
}

:root[data-theme="dark"] .promo-offer h2 {
  color: #f8fafc;
}

:root[data-theme="dark"] .promo-offer .ghost-button {
  color: #f8fafc;
  background: #202830;
  border-color: #52606c;
}

:root[data-theme="dark"] .promo-offer .ghost-button:hover {
  background: #2a333c;
  border-color: #f3f6f8;
}

.price {
  color: var(--ink);
  font-size: 38px;
  font-weight: 900;
  line-height: 1;
}

.price span {
  color: var(--muted);
  font-size: 15px;
  font-weight: 600;
}

.tariff-specs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.tariff-specs div {
  min-height: 66px;
  padding: 11px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.tariff-specs strong {
  display: block;
}

.card-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
  align-self: end;
}

.card-actions > * {
  width: 100%;
  min-width: 0;
}

.card-actions .primary-button {
  grid-column: 1 / -1;
}

.split-layout {
  display: grid;
  grid-template-columns: 0.35fr 1fr;
  gap: 24px;
  align-items: start;
}

.photo-story {
  padding-top: 50px;
}

.life-photo-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) repeat(2, minmax(0, 0.8fr));
  gap: 16px;
  align-items: stretch;
}

.life-photo-card {
  position: relative;
  min-height: 310px;
  margin: 0;
  overflow: hidden;
  background: var(--panel-dark);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow-soft);
}

.life-photo-card.is-large {
  min-height: 420px;
}

.life-photo-card img {
  width: 100%;
  height: 100%;
  min-height: inherit;
  object-fit: cover;
  transition: transform 0.35s ease, filter 0.35s ease;
}

.life-photo-card::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(17, 19, 21, 0.08), rgba(17, 19, 21, 0.68));
  pointer-events: none;
}

.life-photo-card figcaption {
  position: absolute;
  right: 16px;
  bottom: 16px;
  left: 16px;
  z-index: 1;
  color: #ffffff;
  font-size: 18px;
  font-weight: 900;
  text-shadow: 0 2px 18px rgba(0, 0, 0, 0.36);
}

.life-photo-card:hover img {
  filter: saturate(1.04);
  transform: scale(1.035);
}

.service-icon {
  display: grid;
  place-items: center;
  width: 50px;
  height: 50px;
  color: #ffffff;
  background: var(--ink);
  border-radius: var(--radius);
}

.service-icon svg {
  width: 24px;
  height: 24px;
}

.service-card.is-connected {
  border-color: var(--ink);
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  min-width: 0;
  max-width: 100%;
}

.faq-list {
  display: grid;
  gap: 10px;
}

.faq-list details {
  padding: 0;
  overflow: hidden;
}

.faq-list summary {
  min-height: 62px;
  padding: 18px 20px;
  color: var(--ink);
  font-weight: 900;
  cursor: pointer;
  list-style: none;
}

.faq-list summary::-webkit-details-marker {
  display: none;
}

.faq-list summary::after {
  content: "+";
  float: right;
  color: var(--muted);
}

.faq-list details[open] summary::after {
  content: "−";
}

.faq-list p {
  margin: 0;
  padding: 0 20px 20px;
  max-width: 820px;
}

.catalog-layout {
  display: grid;
  grid-template-columns: 280px minmax(0, 1fr);
  gap: 18px;
  align-items: start;
}

.filters {
  position: sticky;
  top: 104px;
  display: grid;
  gap: 16px;
  padding: 20px;
}

.filters h2,
.checkout-panel h2 {
  margin-bottom: 0;
  font-size: 22px;
}

.filters label {
  display: grid;
  gap: 8px;
  color: var(--muted);
  font-weight: 700;
}

select,
input,
textarea {
  width: 100%;
  min-height: 46px;
  color: var(--ink);
  background: var(--panel);
  border: 1px solid var(--line-strong);
  border-radius: var(--radius);
  padding: 10px 12px;
  outline: none;
  transition: border-color 0.18s ease, box-shadow 0.18s ease;
}

:root[data-theme="dark"] select,
:root[data-theme="dark"] input,
:root[data-theme="dark"] textarea {
  color-scheme: dark;
}

select:focus,
input:focus,
textarea:focus {
  border-color: var(--ink);
  box-shadow: 0 0 0 3px var(--focus-ring);
}

textarea {
  resize: vertical;
}

input[type="range"] {
  accent-color: var(--ink);
  padding: 0;
}

.catalog-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-bottom: 14px;
}

.compare-panel {
  display: grid;
  gap: 18px;
  margin-top: 18px;
  padding: 20px;
  overflow: hidden;
}

.compare-panel.is-highlighted {
  animation: compareHighlight 1.1s ease;
}

.compare-empty {
  display: grid;
  gap: 6px;
  color: var(--muted);
}

.compare-showcase-empty {
  grid-template-columns: 54px minmax(0, 1fr);
  gap: 14px;
  align-items: center;
  min-height: 116px;
  padding: 18px;
  background: var(--accent-soft);
  border: 1px dashed var(--line-strong);
  border-radius: var(--radius);
}

.compare-empty-icon {
  display: grid;
  place-items: center;
  width: 54px;
  height: 54px;
  color: var(--bg-raised);
  background: var(--ink);
  border-radius: var(--radius);
}

.compare-empty strong {
  display: block;
  margin-bottom: 2px;
  color: var(--ink);
}

.compare-hero {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: flex-start;
}

.compare-hero h2 {
  margin-bottom: 8px;
}

.compare-hero p:not(.eyebrow) {
  max-width: 760px;
  margin: 0;
}

.compare-card-grid {
  display: grid;
  grid-template-columns: repeat(var(--compare-count), minmax(0, 1fr));
  gap: 14px;
}

.compare-card {
  display: grid;
  gap: 14px;
  min-height: 100%;
  padding: 16px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.compare-card.is-price-best {
  border-color: var(--ink);
  box-shadow: 0 0 0 3px var(--focus-ring);
}

.compare-card header {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 38px;
  gap: 10px;
  align-items: start;
}

.compare-card header small {
  display: block;
  color: var(--muted);
  font-weight: 800;
}

.compare-card h3 {
  margin-bottom: 0;
}

.compact-icon {
  min-width: 38px;
  width: 38px;
  height: 38px;
  padding: 0;
  font-size: 24px;
  line-height: 1;
}

.compare-price {
  display: flex;
  flex-wrap: wrap;
  gap: 6px 8px;
  align-items: baseline;
}

.compare-price strong {
  font-size: 30px;
  line-height: 1;
}

.compare-price span,
.compare-card p {
  color: var(--muted);
}

.compare-price em {
  display: inline-flex;
  min-height: 26px;
  padding: 4px 8px;
  color: var(--bg-raised);
  background: var(--ink);
  border-radius: 999px;
  font-size: 12px;
  font-style: normal;
  font-weight: 900;
}

.compare-card p {
  margin: 0;
}

.compare-metrics {
  display: grid;
  gap: 10px;
}

.compare-metric {
  display: grid;
  gap: 6px;
  padding: 10px;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.compare-metric span {
  color: var(--muted);
  font-size: 13px;
  font-weight: 800;
}

.compare-metric strong {
  font-size: 18px;
}

.compare-metric.is-best {
  border-color: var(--line-strong);
}

.compare-metric.is-best strong::after {
  content: " max";
  color: var(--muted);
  font-size: 11px;
  font-weight: 900;
  text-transform: uppercase;
}

.compare-meter {
  height: 8px;
  overflow: hidden;
  background: var(--accent-soft);
  border-radius: 999px;
}

.compare-meter span {
  display: block;
  width: var(--value);
  height: 100%;
  background: var(--ink);
  border-radius: inherit;
}

.compare-summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.compare-summary div {
  display: grid;
  gap: 3px;
  min-height: 72px;
  padding: 13px;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.compare-summary span {
  color: var(--muted);
  font-size: 13px;
  font-weight: 800;
}

.compare-actions > *,
.admin-actions > *,
.button-row > *,
.page-actions > *,
.cabinet-actions > *,
.hero-actions > * {
  min-width: 0;
}

.coverage-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 0.8fr;
  gap: 18px;
  align-items: stretch;
}

.coverage-map {
  position: relative;
  min-height: 460px;
  overflow: hidden;
  background-color: #e3e8ed;
}

.coverage-photo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  max-width: none;
  object-fit: cover;
  filter: saturate(0.9) contrast(0.95);
}

.coverage-map::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(120deg, rgba(248, 250, 252, 0.62), rgba(248, 250, 252, 0.2)),
    linear-gradient(0deg, rgba(17, 19, 21, 0.18), rgba(17, 19, 21, 0.02));
  pointer-events: none;
}

.map-ring,
.map-station {
  position: absolute;
  z-index: 1;
  display: block;
  border-radius: 50%;
}

.map-ring {
  border: 1px solid rgba(17, 19, 21, 0.26);
  animation: softPulse 4.8s ease-in-out infinite;
}

.ring-a {
  left: 12%;
  top: 16%;
  width: 280px;
  height: 280px;
}

.ring-b {
  right: 12%;
  top: 24%;
  width: 220px;
  height: 220px;
}

.ring-c {
  left: 38%;
  bottom: 8%;
  width: 250px;
  height: 250px;
}

.map-station {
  width: 20px;
  height: 20px;
  background: var(--ink);
  box-shadow: 0 0 0 8px rgba(17, 19, 21, 0.1);
}

.station-a {
  left: 28%;
  top: 42%;
}

.station-b {
  right: 28%;
  top: 48%;
}

.station-c {
  left: 52%;
  bottom: 32%;
}

.services-intro {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  align-items: start;
  min-height: 340px;
  margin: 0 0 18px;
  padding: 34px;
  overflow: hidden;
  color: #ffffff;
  background: var(--panel-dark);
  border: 1px solid rgba(248, 250, 252, 0.16);
  border-radius: var(--radius);
  box-shadow: var(--shadow-soft);
}

.services-intro::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, rgba(17, 19, 21, 0.82), rgba(17, 19, 21, 0.54) 52%, rgba(17, 19, 21, 0.22)),
    linear-gradient(0deg, rgba(17, 19, 21, 0.28), rgba(17, 19, 21, 0.06));
  pointer-events: none;
}

.services-intro > div {
  position: relative;
  z-index: 1;
  display: grid;
  align-content: start;
  justify-items: start;
  gap: 16px;
  padding-top: 26px;
}

.services-intro .eyebrow {
  justify-self: start;
  width: auto;
  min-height: 36px;
  padding: 7px 14px;
  font-size: 14px;
}

.services-intro h2 {
  max-width: 720px;
  margin-bottom: 0;
  color: #ffffff;
  font-size: 34px;
}

.services-intro img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  max-width: none;
  object-fit: cover;
  filter: saturate(0.96) contrast(0.98);
}

.services-intro-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  width: min(680px, 100%);
  max-width: 680px;
}

.services-intro-metrics span {
  min-height: 72px;
  padding: 12px;
  color: #d7d9d9;
  background: rgba(17, 19, 21, 0.5);
  border: 1px solid rgba(248, 250, 252, 0.18);
  border-radius: var(--radius);
  backdrop-filter: blur(12px);
}

.services-intro-metrics strong {
  display: block;
  color: #ffffff;
  font-size: 24px;
  line-height: 1.05;
}

.coverage-info {
  display: grid;
  align-content: center;
  gap: 16px;
  padding: 28px;
}

.metric-grid {
  grid-template-columns: repeat(3, 1fr);
}

.metric-grid div {
  min-height: 96px;
  padding: 16px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.metric-grid strong {
  display: block;
  font-size: 24px;
}

.metric-grid span {
  color: var(--muted);
}

.coverage-check {
  display: grid;
  grid-template-columns: 1fr 0.65fr;
  gap: 12px;
  align-items: end;
  margin-top: 4px;
  padding-top: 16px;
  border-top: 1px solid var(--line);
}

.coverage-check label {
  display: grid;
  gap: 8px;
  color: var(--muted);
  font-weight: 700;
}

.coverage-check .primary-button,
.coverage-result {
  grid-column: 1 / -1;
}

.coverage-result {
  display: none;
  gap: 4px;
  padding: 14px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.coverage-result:not(:empty) {
  display: grid;
}

.coverage-result span {
  color: var(--muted);
}

.cabinet-layout {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1fr);
  gap: 18px;
  align-items: stretch;
}

.balance-panel,
.usage-panel {
  padding: 26px;
}

.balance-panel {
  color: #ffffff;
  background: var(--panel-dark);
  border-color: #303336;
}

.balance-panel p,
.balance-panel .eyebrow {
  color: #d2d4d4;
}

.balance-panel .eyebrow {
  background: #2f3336;
  border-color: #484d51;
}

.balance-panel h1 {
  max-width: 520px;
  color: #ffffff;
  font-size: 44px;
}

.balance-value {
  margin: 20px 0;
  color: #ffffff;
  font-size: 58px;
  font-weight: 900;
  line-height: 1;
}

.usage-panel {
  display: grid;
  gap: 14px;
}

.usage-item {
  display: grid;
  grid-template-columns: 94px 1fr;
  gap: 18px;
  align-items: center;
  min-height: 112px;
  padding: 14px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.meter {
  display: grid;
  place-items: center;
  width: 82px;
  height: 82px;
  border: 10px solid #111315;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: inset 0 0 0 8px #d5dde4;
}

.meter::before {
  content: none;
  grid-area: 1 / 1;
  width: 60px;
  height: 60px;
  background: #ffffff;
  border-radius: 50%;
}

.meter span {
  z-index: 1;
  grid-area: 1 / 1;
  color: #111315;
  font-weight: 900;
}

.operations-list,
.cart-list,
.admin-table {
  display: grid;
  gap: 10px;
}

.operations-list div,
.cart-item,
.admin-table div {
  display: grid;
  grid-template-columns: minmax(96px, 120px) minmax(0, 1fr) auto;
  gap: 14px;
  align-items: center;
  min-height: 64px;
  padding: 15px 16px;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.operations-list div > *,
.cart-item > *,
.admin-table div > * {
  min-width: 0;
}

.operations-list em,
.checkout-row strong,
.admin-table em {
  color: var(--ink);
  font-style: normal;
  font-weight: 900;
}

.cart-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 310px;
  gap: 18px;
  align-items: start;
}

.cart-item {
  grid-template-columns: minmax(0, 1fr) auto auto;
}

.checkout-panel {
  position: sticky;
  top: 104px;
  display: grid;
  gap: 16px;
  padding: 18px;
}

.checkout-row {
  display: flex;
  justify-content: space-between;
  gap: 14px;
}

.cabinet-dashboard {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
  gap: 18px;
  align-items: stretch;
  margin-bottom: 18px;
}

.account-panel,
.cabinet-summary,
.cabinet-card {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow-soft);
}

.account-panel {
  display: grid;
  gap: 22px;
  padding: 24px;
  color: #ffffff;
  background: var(--panel-dark);
  border-color: #303336;
}

.account-top {
  display: grid;
  grid-template-columns: 64px 1fr;
  gap: 16px;
  align-items: center;
}

.account-avatar {
  display: grid;
  place-items: center;
  width: 64px;
  height: 64px;
  color: #111315;
  background: #f8fafc;
  border: 1px solid #d5dde4;
  border-radius: var(--radius);
  font-size: 22px;
  font-weight: 900;
}

.account-panel .eyebrow {
  color: #f8fafc;
  background: #2f3336;
  border-color: #484d51;
}

.account-panel h1 {
  margin-bottom: 6px;
  color: #ffffff;
  font-size: clamp(38px, 5vw, 58px);
}

.account-meta {
  color: #d2d4d4;
}

.balance-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.balance-strip div {
  min-height: 94px;
  padding: 14px;
  background: #222528;
  border: 1px solid #3c4043;
  border-radius: var(--radius);
}

.balance-strip span,
.summary-card span,
.summary-card small {
  display: block;
  color: var(--muted);
}

.account-panel .balance-strip span {
  color: #bfc2c2;
}

.balance-strip strong {
  display: block;
  margin-top: 6px;
  color: #ffffff;
  font-size: 22px;
  line-height: 1.12;
}

.balance-strip #balanceValue {
  font-size: 30px;
}

.cabinet-summary {
  display: grid;
  gap: 10px;
  padding: 14px;
}

.summary-card {
  min-height: 112px;
  padding: 16px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.summary-card strong {
  display: block;
  margin: 8px 0 4px;
  font-size: 24px;
}

.summary-card .mini-button {
  margin-top: 12px;
}

.cabinet-card {
  padding: 22px;
}

.usage-card {
  margin-bottom: 18px;
}

.cabinet-card .section-heading {
  margin-bottom: 16px;
}

.cabinet-card .usage-panel {
  display: grid;
  gap: 12px;
  padding: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.cabinet-card .usage-item {
  display: grid;
  grid-template-columns: minmax(170px, 0.34fr) minmax(180px, 1fr) 54px;
  gap: 14px;
  align-items: center;
  min-height: 78px;
  padding: 16px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.usage-copy {
  display: grid;
  gap: 2px;
}

.usage-copy strong {
  font-size: 18px;
}

.usage-bar {
  height: 12px;
  overflow: hidden;
  background: #d5dde4;
  border: 1px solid #c4ced8;
  border-radius: 999px;
}

.usage-bar span {
  display: block;
  width: var(--value);
  height: 100%;
  background: #111315;
  border-radius: inherit;
  transform-origin: left center;
  animation: barGrow 0.7s ease both;
}

.cabinet-card .usage-item em {
  color: var(--ink);
  font-style: normal;
  font-weight: 900;
  text-align: right;
}

.cabinet-content-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 0.8fr);
  gap: 18px;
  align-items: start;
}

.operation-item em.positive {
  color: var(--positive);
}

.operation-item em.negative {
  color: var(--negative);
}

:root[data-theme="dark"] .usage-bar {
  background: #101316;
  border-color: #45505a;
}

:root[data-theme="dark"] .usage-bar span {
  background: #f3f6f8;
}

.connected-list {
  display: grid;
  gap: 10px;
}

.connected-item {
  display: grid;
  grid-template-columns: 50px 1fr auto;
  gap: 12px;
  align-items: center;
  min-height: 74px;
  padding: 12px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.connected-item small {
  display: block;
  color: var(--muted);
}

@keyframes barGrow {
  from {
    transform: scaleX(0);
  }

  to {
    transform: scaleX(1);
  }
}

.admin-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
  overflow-x: auto;
}

.admin-view {
  display: none;
}

.admin-view.is-active {
  display: grid;
  gap: 16px;
}

.admin-form,
.admin-tools,
.feedback-panel,
.reviews-panel,
.map-panel {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow-soft);
}

.admin-form {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  padding: 16px;
  align-items: end;
}

.admin-tools {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 220px;
  gap: 12px;
  padding: 16px;
  align-items: end;
}

.admin-form label,
.admin-tools label,
.feedback-panel label {
  display: grid;
  gap: 8px;
  color: var(--muted);
  font-weight: 700;
}

.admin-wide,
.admin-actions {
  grid-column: 1 / -1;
}

.admin-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.admin-table {
  padding: 12px;
}

.admin-table div {
  grid-template-columns: minmax(120px, 160px) minmax(0, 1fr) minmax(0, max-content);
}

.admin-table small {
  display: block;
  margin-top: 4px;
  color: var(--muted-2);
}

.admin-review-row {
  grid-template-columns: 56px minmax(0, 1fr) minmax(0, max-content) !important;
}

.feedback-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 0.44fr);
  gap: 18px;
  align-items: start;
}

.feedback-layout.reviews-only {
  grid-template-columns: 1fr;
}

.reviews-panel,
.feedback-panel,
.map-panel {
  padding: 22px;
}

.reviews-list {
  display: grid;
  gap: 12px;
}

.review-toolbar {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 220px;
  gap: 12px;
  align-items: end;
  margin-bottom: 14px;
}

.review-stats {
  display: flex;
  align-items: center;
  gap: 12px;
  min-height: 64px;
  padding: 12px 14px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.review-stats strong {
  font-size: 34px;
  line-height: 1;
}

.review-stats span,
.review-toolbar label span {
  color: var(--muted);
}

.review-toolbar label {
  display: grid;
  gap: 8px;
  font-weight: 700;
}

.review-card {
  display: grid;
  gap: 10px;
  padding: 16px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.review-head {
  display: flex;
  align-items: center;
  gap: 12px;
}

.review-head > span:last-child {
  display: grid;
  gap: 2px;
}

.review-avatar {
  display: grid;
  place-items: center;
  width: 48px;
  height: 48px;
  flex: 0 0 48px;
  overflow: hidden;
  color: var(--bg-raised);
  background: var(--ink);
  border: 1px solid var(--line-strong);
  border-radius: 50%;
  font-weight: 900;
}

.review-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.review-card .review-avatar {
  color: var(--bg-raised);
}

.review-answer {
  display: grid;
  gap: 4px;
  padding: 12px;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.review-answer p {
  margin: 0;
}

.review-card span,
.review-card small,
.review-card p {
  color: var(--muted);
}

.review-card em {
  color: var(--ink);
  font-style: normal;
  letter-spacing: 0.08em;
}

.feedback-panel form {
  display: grid;
  gap: 12px;
}

.map-panel {
  display: grid;
  grid-template-columns: 0.36fr minmax(0, 1fr);
  gap: 18px;
  align-items: stretch;
  margin-top: 18px;
}

.map-panel iframe {
  width: 100%;
  min-height: 360px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--accent-soft);
}

.centered-page {
  display: none;
  place-items: center;
  min-height: 58vh;
  padding: 54px 22px;
  text-align: center;
}

.centered-page.is-active {
  display: grid;
}

.state-mark {
  display: grid;
  place-items: center;
  width: 82px;
  height: 82px;
  color: #ffffff;
  background: var(--ink);
  border-radius: 50%;
  font-size: 32px;
  font-weight: 900;
}

.state-mark.muted {
  color: var(--ink);
  background: var(--accent-soft);
}

.footer {
  display: flex;
  justify-content: space-between;
  gap: 24px;
  margin-top: 26px;
  padding: 28px 0 96px;
  color: var(--muted);
  border-top: 1px solid var(--line);
}

.footer div {
  display: grid;
  gap: 4px;
}

.footer strong,
.footer a {
  color: var(--ink);
}

.mobile-nav {
  position: fixed;
  right: 16px;
  bottom: 14px;
  left: 16px;
  z-index: 40;
  display: none;
  grid-template-columns: repeat(6, 1fr);
  gap: 4px;
  padding: 6px;
  background: var(--mobile-glass-bg);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  backdrop-filter: blur(14px);
}

:root[data-theme="dark"] .metric-grid div,
:root[data-theme="dark"] .tariff-specs div,
:root[data-theme="dark"] .summary-card,
:root[data-theme="dark"] .cabinet-card .usage-item,
:root[data-theme="dark"] .connected-item,
:root[data-theme="dark"] .review-stats,
:root[data-theme="dark"] .review-card,
:root[data-theme="dark"] .config-summary,
:root[data-theme="dark"] .navigator-link,
:root[data-theme="dark"] .coverage-result {
  background: var(--accent-soft);
  border-color: var(--line);
}

:root[data-theme="dark"] .service-icon,
:root[data-theme="dark"] .navigator-icon,
:root[data-theme="dark"] .state-mark {
  color: #101316;
  background: #f3f6f8;
}

:root[data-theme="dark"] .empty-state {
  background: var(--panel);
}

.mobile-nav a,
.mobile-nav button {
  display: grid;
  justify-items: center;
  gap: 4px;
  min-width: 0;
  min-height: 56px;
  padding: 7px 4px;
  color: var(--muted);
  background: transparent;
  border: 0;
  border-radius: var(--radius);
  font-size: 11px;
  text-align: center;
  line-height: 1.1;
  overflow: hidden;
  overflow-wrap: anywhere;
}

.mobile-nav a span,
.mobile-nav button span {
  min-width: 0;
  max-width: 100%;
}

.mobile-nav a.is-active,
.mobile-nav button.is-active {
  color: var(--ink);
  background: var(--accent-soft);
}

.mobile-nav .navigator-toggle {
  position: relative;
}

.mobile-nav .navigator-toggle .chevron-down {
  position: absolute;
  top: 6px;
  right: 8px;
  width: 12px;
  height: 12px;
}

dialog {
  position: relative;
  width: min(560px, calc(100% - 28px));
  max-height: calc(100svh - 32px);
  padding: 0;
  color: var(--ink);
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: auto;
}

dialog::backdrop {
  background: rgba(17, 19, 21, 0.56);
  backdrop-filter: blur(3px);
}

.dialog-close {
  position: absolute;
  top: 14px;
  right: 14px;
  z-index: 2;
  width: 40px;
  min-width: 40px;
  height: 40px;
  padding: 0;
  font-size: 24px;
  line-height: 1;
}

.dialog-close:hover {
  transform: none;
}

.dialog-body {
  display: grid;
  gap: 14px;
  padding: 66px 22px 22px;
}

.dialog-body form,
.cart-modal {
  display: grid;
  gap: 12px;
}

.dialog-body label {
  display: grid;
  gap: 8px;
  color: var(--muted);
  font-weight: 700;
}

.auth-dialog {
  padding-top: 66px;
}

.auth-switch {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 6px;
  padding: 4px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.auth-switch button {
  min-height: 40px;
  color: var(--muted);
  background: transparent;
  border: 1px solid transparent;
  border-radius: var(--radius);
  font-weight: 800;
}

.auth-switch button.is-active,
.auth-switch button:hover {
  color: var(--ink);
  background: var(--panel);
  border-color: var(--line);
}

.payment-methods {
  display: grid;
  gap: 8px;
  padding: 0;
  margin: 0;
  border: 0;
}

.payment-methods legend {
  margin-bottom: 8px;
  color: var(--muted);
  font-weight: 700;
}

.payment-options {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px;
}

.payment-option {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 8px;
  align-items: start;
  min-height: 74px;
  padding: 12px;
  color: var(--ink);
  background: var(--panel);
  border: 1px solid var(--line-strong);
  border-radius: var(--radius);
  cursor: pointer;
  font-weight: 400;
  transition: border-color 0.18s ease, box-shadow 0.18s ease;
}

.payment-option:has(input:checked) {
  border-color: var(--ink);
  box-shadow: 0 0 0 3px var(--focus-ring);
}

.payment-option input {
  width: auto;
  min-height: auto;
  margin-top: 3px;
  padding: 0;
  accent-color: var(--ink);
}

.payment-option span,
.payment-option strong,
.payment-option small {
  display: block;
}

.payment-option small {
  margin-top: 4px;
  color: var(--muted);
  font-size: 12px;
  line-height: 1.35;
}

.sbp-payment {
  gap: 16px;
}

.sbp-payment-layout {
  display: grid;
  grid-template-columns: minmax(180px, 220px) minmax(0, 1fr);
  gap: 18px;
  align-items: start;
}

.sbp-qr {
  display: grid;
  place-items: center;
  aspect-ratio: 1;
  padding: 14px;
  background: #ffffff;
  border: 1px solid #d5dde4;
  border-radius: var(--radius);
}

.sbp-qr-svg {
  width: 100%;
  height: auto;
  fill: #111315;
  stroke: none;
  shape-rendering: crispEdges;
}

.sbp-qr-bg {
  fill: #ffffff;
}

.sbp-qr-cells {
  fill: #111315;
}

:root[data-theme="dark"] .sbp-qr {
  background: #ffffff;
  border-color: #52606c;
}

.sbp-payment-info {
  display: grid;
  gap: 12px;
}

.sbp-payment-info p {
  margin: 0;
  color: var(--muted);
}

.navigator-list {
  display: grid;
  gap: 10px;
}

.navigator-popover {
  position: fixed;
  z-index: 90;
  width: min(350px, calc(100vw - 24px));
  padding: 12px;
  color: var(--ink);
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.navigator-popover[hidden] {
  display: none;
}

.navigator-popover::before {
  content: "";
  position: absolute;
  left: var(--arrow-left, 50%);
  width: 14px;
  height: 14px;
  background: var(--panel);
  transform: translateX(-50%) rotate(45deg);
}

.navigator-popover[data-placement="bottom"]::before {
  top: -8px;
  border-top: 1px solid var(--line);
  border-left: 1px solid var(--line);
}

.navigator-popover[data-placement="top"]::before {
  bottom: -8px;
  border-right: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}

.navigator-title {
  display: block;
  margin: 2px 4px 10px;
  font-size: 15px;
}

.navigator-link {
  display: grid;
  grid-template-columns: 44px minmax(0, 1fr);
  gap: 12px;
  align-items: center;
  min-height: 72px;
  padding: 14px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
}

.navigator-link:hover {
  transform: translateY(-2px);
  background: var(--panel);
  border-color: var(--line-strong);
  box-shadow: var(--shadow-soft);
}

.navigator-icon {
  display: grid;
  place-items: center;
  width: 44px;
  height: 44px;
  color: #ffffff;
  background: var(--ink);
  border-radius: var(--radius);
}

.navigator-link strong,
.navigator-link span:not(.navigator-icon) {
  display: block;
}

.navigator-link strong {
  color: var(--ink);
  font-size: 16px;
}

.navigator-link span:not(.navigator-icon) {
  color: var(--muted);
  font-size: 14px;
}

.dialog-body .inline-check {
  display: flex;
  gap: 10px;
  align-items: center;
}

.dialog-body .inline-check input {
  width: auto;
  min-height: auto;
}

.config-summary {
  display: grid;
  gap: 8px;
  padding: 12px;
  background: var(--accent-soft);
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.config-summary p {
  margin: 0;
}

.quiz-result {
  display: grid;
  gap: 10px;
}

.toast-stack {
  position: fixed;
  right: 18px;
  bottom: 96px;
  z-index: 70;
  display: grid;
  gap: 10px;
  width: min(340px, calc(100% - 36px));
}

.toast {
  padding: 14px 16px;
  color: var(--bg-raised);
  background: var(--ink);
  border: 1px solid var(--ink);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  transition: opacity 0.2s ease, transform 0.2s ease;
  animation: pageEnter 0.25s ease both;
}

.toast.is-hiding {
  opacity: 0;
  transform: translateY(8px);
}

.toast strong {
  display: block;
  margin-bottom: 2px;
}

.empty-state {
  display: grid;
  place-items: center;
  min-height: 190px;
  padding: 24px;
  color: var(--muted);
  background: var(--panel);
  border: 1px dashed var(--line-strong);
  border-radius: var(--radius);
  text-align: center;
}

.reveal {
  opacity: 0;
  transform: translateY(22px);
}

.reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.5s ease var(--reveal-delay, 0ms), transform 0.5s ease var(--reveal-delay, 0ms);
}

@media (max-width: 1040px) {
  .app-shell {
    width: min(100% - 24px, 840px);
  }

  .main-nav {
    display: none;
  }

  .topbar {
    grid-template-columns: 1fr auto;
  }

  .promo-slide {
    grid-template-columns: 1fr;
    min-height: calc(100svh - 82px);
    padding: 48px 24px 32px;
  }

  .promo-copy h1 {
    font-size: 48px;
  }

  .promo-visual {
    min-height: 320px;
    justify-items: start;
    align-content: start;
  }

  .catalog-layout,
  .coverage-layout,
  .cabinet-dashboard,
  .cabinet-content-grid,
  .feedback-layout,
  .map-panel,
  .life-photo-grid,
  .services-intro,
  .cabinet-layout,
  .cart-layout,
  .split-layout {
    grid-template-columns: 1fr;
  }

  .admin-form {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .tariff-grid,
  .catalog-grid,
  .service-row,
  .service-grid,
  .support-grid {
    grid-template-columns: 1fr 1fr;
  }

  .filters,
  .checkout-panel {
    position: static;
  }

  .mobile-nav {
    display: grid;
  }
}

@media (max-width: 640px) {
  .app-shell {
    width: min(calc(100vw - 20px), 430px);
  }

  .topbar {
    top: 8px;
    display: flex;
    justify-content: space-between;
    gap: 8px;
    min-height: 66px;
    padding: 8px;
  }

  .brand {
    flex: 1 1 auto;
    min-width: 0;
  }

  .brand-copy {
    min-width: 0;
  }

  .brand-copy strong {
    overflow: hidden;
    max-width: 150px;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .top-actions {
    flex: 0 0 auto;
  }

  .brand-logo {
    width: 44px;
    height: 44px;
  }

  .brand-copy small,
  .top-actions .icon-button {
    display: none;
  }

  .top-actions .theme-toggle {
    display: inline-grid;
  }

  .page {
    padding-top: 30px;
  }

  h1 {
    font-size: 36px;
    line-height: 1.03;
  }

  h2 {
    font-size: 26px;
  }

  .full-bleed-slider {
    min-height: calc(100svh - 82px);
    margin-bottom: 34px;
  }

  .full-bleed-slider .slider-viewport,
  .promo-slide {
    min-height: calc(100svh - 82px);
  }

  .promo-slide {
    gap: 18px;
    padding: 30px 18px 86px;
  }

  .promo-slide::before {
    inset: 12px;
  }

  .promo-copy h1 {
    font-size: 34px;
  }

  .promo-copy p:not(.eyebrow) {
    font-size: 17px;
  }

  .promo-copy .primary-button {
    width: 100%;
  }

  .promo-visual {
    min-height: auto;
  }

  .slide-dashboard,
  .slide-feature-list {
    width: 100%;
  }

  .slide-dashboard {
    min-height: 170px;
    padding: 18px;
  }

  .slide-dashboard strong {
    font-size: 38px;
  }

  .slide-dashboard small {
    font-size: 15px;
  }

  .slide-feature-list span {
    min-height: 44px;
    padding: 11px 12px;
  }

  .life-photo-card,
  .life-photo-card.is-large {
    min-height: 260px;
  }

  .visual-phone,
  .visual-meter,
  .visual-server {
    right: 24px;
    bottom: 24px;
    transform: scale(0.78);
    transform-origin: right bottom;
  }

  .visual-card-a {
    top: 38px;
    left: 24px;
  }

  .visual-card-b {
    top: 90px;
    right: 24px;
  }

  .slider-controls {
    bottom: 22px;
  }

  .section-heading,
  .page-head,
  .page-actions,
  .cabinet-actions {
    align-items: stretch;
    flex-direction: column;
  }

  .tariff-grid,
  .catalog-grid,
  .service-row,
  .service-grid,
  .support-grid,
  .promo-offer-grid,
  .legal-grid,
  .metric-grid,
  .tariff-specs,
  .coverage-check,
  .review-toolbar,
  .admin-tools {
    grid-template-columns: 1fr;
  }

  .tariff-card,
  .service-card,
  .info-card,
  .filters,
  .balance-panel,
  .usage-panel,
  .checkout-panel,
  .coverage-info {
    padding: 18px;
  }

  .card-photo,
  .offer-photo {
    width: calc(100% + 36px);
    margin: -18px -18px 0;
  }

  .services-intro {
    min-height: 380px;
    padding: 20px;
  }

  .services-intro h2 {
    font-size: 26px;
  }

  .services-intro-metrics {
    grid-template-columns: 1fr;
  }

  .card-actions {
    grid-template-columns: 1fr;
  }

  .compare-panel {
    padding: 16px;
  }

  .compare-hero,
  .compare-showcase-empty {
    grid-template-columns: 1fr;
  }

  .compare-hero {
    display: grid;
  }

  .compare-card-grid,
  .compare-summary {
    grid-template-columns: 1fr;
  }

  .compare-price strong {
    font-size: 26px;
  }

  .balance-panel h1 {
    font-size: 32px;
  }

  .balance-value {
    font-size: 42px;
  }

  .usage-item {
    grid-template-columns: 82px 1fr;
  }

  .balance-strip,
  .cabinet-card .usage-item,
  .connected-item {
    grid-template-columns: 1fr;
  }

  .cabinet-card .usage-item em {
    text-align: left;
  }

  .operations-list div,
  .cart-item,
  .admin-table div,
  .admin-form {
    grid-template-columns: 1fr;
  }

  .admin-review-row {
    grid-template-columns: 48px minmax(0, 1fr) !important;
  }

  .admin-review-row .button-row {
    grid-column: 1 / -1;
  }

  .payment-options {
    grid-template-columns: 1fr;
  }

  .payment-option {
    min-height: auto;
  }

  .sbp-payment-layout {
    grid-template-columns: 1fr;
  }

  .sbp-qr {
    width: min(240px, 100%);
    margin: 0 auto;
  }

  .review-card div {
    display: grid;
  }

  .footer {
    display: grid;
  }
}

@media (max-width: 420px) {
  .app-shell {
    width: calc(100vw - 16px);
  }

  h1 {
    font-size: 34px;
  }

  h2 {
    font-size: 24px;
  }

  .brand-copy strong {
    font-size: 16px;
  }

  .cart-pill {
    min-width: 54px;
    padding: 0 10px;
  }

  .promo-copy h1 {
    font-size: 31px;
  }

  .account-top {
    grid-template-columns: 1fr;
  }

  .account-avatar {
    width: 56px;
    height: 56px;
  }

  .promo-visual {
    min-height: auto;
  }

  .visual-card {
    min-width: 94px;
    min-height: 46px;
    font-size: 13px;
  }

  dialog {
    width: calc(100% - 18px);
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    scroll-behavior: auto !important;
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }

  .reveal {
    opacity: 1;
    transform: none;
  }
}

